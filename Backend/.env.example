# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgres://username:password@localhost:5432/classiq

# Auth
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# School branding for printed exercise sheets
SCHOOL_NAME=ClassIQ
SCHOOL_DISTRICT=Nyabihu District
SCHOOL_WEBSITE=example.ac.rw
SCHOOL_EMAIL=info@example.ac.rw
SCHOOL_PHONE=+250700000000
# Optional absolute or relative filesystem path to logo image
SCHOOL_LOGO_PATH=
CURRENT_TERM=Term 1
ACADEMIC_YEAR=2026
EXERCISE_DURATION_MINUTES=120

# AI (Gemini)
GEMINI_API_KEY=replace_with_your_gemini_key
# Optional rotation alternatives:
# GEMINI_API_KEYS=key_one,key_two
# GEMINI_API_KEY_1=key_one
# GEMINI_API_KEY_2=key_two
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_MS=1200
GEMINI_RETRY_MAX_WAIT_MS=60000

# Local ClassIQ AI limiter
AI_LIMIT_WINDOW_MS=60000
AI_LIMIT_MAX=5

# Student workload guardrails
MAX_DAILY_EXERCISES=3
MAX_DAILY_SUBJECTS=3
WEEKLY_ROTATION_SUBJECTS=3

